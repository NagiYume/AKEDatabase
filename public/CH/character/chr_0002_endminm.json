    "skills": [
        {
            "name": "锁闭序列",
            "icon": "/public/images/character/skillicon/icon_combo_skill_endmin_01.png",
            "description": "当小队内其他干员的连携技造成伤害时可以发动。\n冲到敌人身边，对其造成<@ba.pd>物理伤害</>，并附着<@ba.key>源石结晶</>，在一段时间内将其封印。施加<#ba.physicalstatus>物理异常</>和<#ba.noguard>破防</>会击碎<@ba.key>源石结晶</>并额外造成<@ba.pd>物理伤害</>。",
            "groupType": "ComboSkill",
            "skillIds": [
                "chr_0002_endminm_combo_skill"
            ]
        },
        {
            "name": "毁伤序列",
            "icon": "/public/images/character/skillicon/icon_attack_sword.png",
            "description": "普通攻击：\n对敌人进行至多5段攻击，造成<@ba.pd>物理伤害</>。作为主控干员时，<#ba.lastcombo>重击</>会造成<@ba.poise>{poise:0}</>点失衡。\n \n下落攻击：\n处于空中时使用普通攻击，会下落并攻击附近敌人，造成<@ba.pd>物理伤害</>。\n \n处决攻击：\n附近有敌人处于失衡状态时使用普通攻击，将处决该敌人，造成大量<@ba.pd>物理伤害</>并恢复一定技力。",
            "groupType": "NormalAttack",
            "skillIds": [
                "chr_0002_endminm_attack1",
                "chr_0002_endminm_attack2",
                "chr_0002_endminm_attack3",
                "chr_0002_endminm_attack4",
                "chr_0002_endminm_attack5",
                "chr_0002_endminm_power_attack",
                "chr_0002_endminm_plunging_attack_end"
            ]
        },
        {
            "name": "构成序列",
            "icon": "/public/images/character/skillicon/icon_skill_endmin_01.png",
            "description": "使用<@ba.key>源石结晶</>冲击前方一定范围内的敌人，造成<@ba.pd>物理伤害</>和<#ba.crush>猛击</>。",
            "groupType": "NormalSkill",
            "skillIds": [
                "chr_0002_endminm_normal_skill"
            ]
        },
        {
            "name": "轰击序列",
            "icon": "/public/images/character/skillicon/icon_ultimate_skill_endmin_01.png",
            "description": "使用<@ba.key>源石结晶</>轰击地面，对前方扇形范围内的敌人造成大量<@ba.pd>物理伤害</>。如果敌人身上附着<@ba.key>源石结晶</>，则击碎<@ba.key>源石结晶</>并额外造成一次<@ba.pd>物理伤害</>。",
            "groupType": "UltimateSkill",
            "skillIds": [
                "chr_0002_endminm_ultimate_skill"
            ]
        }
    ],
