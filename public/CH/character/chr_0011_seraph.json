    "skills": [
        {
            "name": "压力测试",
            "icon": "/public/images/character/skillicon/icon_combo_skill_seraph_01.png",
            "description": "当<@ba.key>支援晶体</>的生命回复次数耗尽后可以发动。\n短暂蓄力后将<@ba.key>支援晶体</>丢向敌人，造成<@ba.cryst>寒冷伤害</>并施加<#ba.crystinflict>寒冷附着</>。",
            "groupType": "ComboSkill",
            "skillIds": [
                "chr_0011_seraph_combo_skill"
            ]
        },
        {
            "name": "冷却",
            "icon": "/public/images/character/skillicon/icon_attack_funnel.png",
            "description": "普通攻击：\n对敌人进行至多5段攻击，造成<@ba.cryst>寒冷伤害</>。作为主控干员时，<#ba.lastcombo>重击</>会造成<@ba.poise>{poise:0}</>点失衡。\n\n下落攻击：\n处于空中时使用普通攻击，会下落并攻击附近敌人，造成<@ba.cryst>寒冷伤害</>。\n\n处决攻击：\n附近有敌人处于失衡状态时使用普通攻击，将处决该敌人，造成大量<@ba.cryst>寒冷伤害</>并恢复一定技力。",
            "groupType": "NormalAttack",
            "skillIds": [
                "chr_0011_seraph_attack1",
                "chr_0011_seraph_attack2",
                "chr_0011_seraph_attack3",
                "chr_0011_seraph_attack4",
                "chr_0011_seraph_attack5",
                "chr_0011_seraph_power_attack",
                "chr_0011_seraph_plunging_attack_end"
            ]
        },
        {
            "name": "分布式拒绝服务",
            "icon": "/public/images/character/skillicon/icon_skill_seraph_01.png",
            "description": "召唤<@ba.key>支援晶体</>在一段时间内环绕主控干员。\n当主控干员对敌人造成<#ba.lastcombo>重击</>后<@ba.key>支援晶体</>为其回复生命值，该效果最多可触发2次。意志可以额外提高治疗量。\n若触发回复时主控干员生命值已满，则额外对其施加一段时间的<#ba.spellenhance>法术增幅</>，该效果无法叠加。",
            "groupType": "NormalSkill",
            "skillIds": [
                "chr_0011_seraph_normal_skill"
            ]
        },
        {
            "name": "栈溢出",
            "icon": "/public/images/character/skillicon/icon_ultimate_skill_seraph_01.png",
            "description": "对全队施加一段时间的<#ba.crystenhance>寒冷增幅</>和<#ba.naturalenhance>自然增幅</>，智识可以额外提高该增幅效果。",
            "groupType": "UltimateSkill",
            "skillIds": [
                "chr_0011_seraph_ultimate_skill"
            ]
        }
    ],
