    "skills": [
        {
            "name": "疾电法",
            "icon": "/public/images/character/skillicon/icon_attack_funnel.png",
            "description": "庄方宜可以进行至多五段普通攻击，对敌人造成电磁伤害。处决敌人时，将造成大量电磁伤害并恢复一定法力。",
            "groupType": 0,
            "skillIds": [
                "chr_0030_zhuangfy_NormalAttack"
            ]
        },
        {
            "name": "惊霆诀",
            "icon": "/public/images/character/skillicon/icon_skill_zhuangfy_01.png",
            "description": "消耗目标的导电状态，使本次战技伤害倍率提高，并生成最多3柄青霆剑。随后引导附近的青霆剑依次雷击目标，造成大量电磁伤害。",
            "groupType": 1,
            "skillIds": [
                "chr_0030_zhuangfy_NormalSkill"
            ]
        },
        {
            "name": "万钧风雷",
            "icon": "/public/images/character/skillicon/icon_ultimate_skill_zhuangfy_01.png",
            "description": "进入天理合真状态，普通攻击获得强化。战技获得强化，可以施加电磁附着。连携技变为范围效果，冷却恢复速度提升。该状态下首次施放战技不消耗技力与导电状态，必定生成3柄青霆剑。",
            "groupType": 2,
            "skillIds": [
                "chr_0030_zhuangfy_UltimateSkill"
            ]
        },
        {
            "name": "一息万变",
            "icon": "/public/images/character/skillicon/icon_combo_skill_zhuangfy_01.png",
            "description": "主控干员重击或处决命中处于电磁附着的目标后可以发动。构造息雷阵法攻击敌人，造成电磁伤害，若敌人处于电磁附着状态则将其转化为导电状态。",
            "groupType": 3,
            "skillIds": [
                "chr_0030_zhuangfy_ComboSkill"
            ]
        }
    ],
